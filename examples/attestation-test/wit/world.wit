// P2 (component model) attestation demo. Imports the ELASTIC TEE HAL and
// exports `run-attestation`. Proplet runs it via the
// `start_app_component_export` path (function_name = "run-attestation") with
// PROPLET_HAL_ENABLED=true.
//
// wit/deps/hal.wit must stay byte-compatible with proplet/wit/hal/hal.wit.

package propeller:attestation-test;

world attestation-test {
  import elastic:hal/platform@0.1.0;
  import elastic:hal/attestation@0.1.0;
  import elastic:hal/random@0.1.0;

  export run-attestation: func() -> string;
}
