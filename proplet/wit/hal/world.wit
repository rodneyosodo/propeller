// ELASTIC TEE HAL — aggregating world for the modular interfaces in this
// directory. One file per interface package keeps cargo-component happy and
// mirrors upstream `wit-modular/` exactly. Bound by
// `proplet/src/hal_component.rs` via a single
// `wasmtime::component::bindgen!` pass.

package elastic:hal-modular@0.1.0;

world elastic-modular-imports {
  import elastic:hal/platform@0.1.0;
  import elastic:hal/attestation@0.1.0;
  import elastic:hal/crypto@0.1.0;
  import elastic:hal/clock@0.1.0;
  import elastic:hal/random@0.1.0;
  import elastic:hal/sockets@0.1.0;
  import elastic:hal/gpu@0.1.0;
  import elastic:hal/resources@0.1.0;
  import elastic:hal/events@0.1.0;
  import elastic:hal/communication@0.1.0;
  import elastic:hal/storage@0.1.0;
}
